# Variables de entorno para Sveltia CMS + Cloudflare Pages
# Copia este archivo como .env en desarrollo local y configura los mismos
# valores como secrets en el dashboard de Cloudflare Pages.

# GitHub OAuth App (https://github.com/settings/developers)
# Authorization callback URL: https://<tu-dominio.pages.dev>/api/auth/callback
GITHUB_CLIENT_ID=your_oauth_client_id
GITHUB_CLIENT_SECRET=your_oauth_client_secret
