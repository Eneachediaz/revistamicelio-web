---
import Hyphae from "./Hyphae.astro";
import Sporangium from "./Sporangium.astro";
import Logo from "./Logo.astro";
import SLabLogo from "./SLabLogo.astro";
const year = new Date().getFullYear();
---

<footer class="mt-32">
  <div class="container-editorial">
    <div class="my-16 md:my-20" aria-hidden="true">
      <Hyphae variant="center" color="hyphae" />
    </div>

    <div class="my-12 flex flex-col items-center gap-4" aria-hidden="true">
      <Sporangium variant="cluster" color="spore" size={36} />
    </div>

    <div class="mx-auto my-12 grid max-w-3xl grid-cols-1 items-center justify-items-center gap-10 sm:grid-cols-[1fr_auto_1fr] sm:gap-12">
      <div class="flex flex-col items-center gap-3 sm:items-end">
        <Logo size="md" />
        <p class="versalita m-0 text-center sm:text-right">Revista · ecología oscura</p>
      </div>

      <div class="hidden h-16 w-px bg-[var(--color-border)] sm:block" aria-hidden="true"></div>
      <div class="block h-px w-16 bg-[var(--color-border)] sm:hidden" aria-hidden="true"></div>

      <div class="flex flex-col items-center gap-3 sm:items-start">
        <SLabLogo size="md" />
        <p class="versalita m-0 text-center sm:text-left">Laboratorio · traducción</p>
      </div>
    </div>

    <div class="my-10" aria-hidden="true">
      <Hyphae variant="trail" color="spore" />
    </div>

    <div class="flex flex-col items-center gap-6 pb-12 text-center md:flex-row md:justify-between md:text-left">
      <p class="versalita">© {year} · Revista Micelio · CC BY-NC 4.0</p>
      <a
        href="https://www.instagram.com/revistamicelio/"
        rel="noopener"
        class="versalita spore-trail text-[var(--color-ink-muted)] hover:text-[var(--color-hyphae-glow)]"
      >
        @revistamicelio
      </a>
    </div>
  </div>
</footer>
