---
/**
 * MediaItem · imagen en su tamaño natural, sin recorte.
 * Muestra la imagen a su aspect-ratio nativo, escalando al ancho del contenedor.
 *
 * Responsive: si la ruta es un portada-*, emite <picture> con las variantes
 * WebP que realmente existen en disco (portada-foo-600.webp, -900, -1200).
 * Las variantes se generan en build con scripts/generate-portada-variants.mjs
 * solo cuando el ancho original excede el target. El browser elige la
 * variante adecuada según viewport y DPR. El fallback <img> es el JPEG
 * original. Si no hay variantes disponibles, emite un <img> simple.
 *
 * Para placeholders con forma fija, usar <div class="media-item" style="aspect-ratio: X/Y"> directamente.
 */
import fs from "node:fs";
import path from "node:path";

interface Props {
  src: string;
  alt: string;
  zoom?: boolean;
  caption?: string;
  href?: string;
  className?: string;
  sizes?: string;
  loading?: "lazy" | "eager";
  fetchpriority?: "auto" | "high" | "low";
}

const {
  src,
  alt,
  zoom = false,
  caption,
  href,
  className = "",
  sizes = "100vw",
  loading = "lazy",
  fetchpriority = "auto",
} = Astro.props;

const Tag = href ? "a" : "div";

const VARIANT_WIDTHS = [600, 900, 1200] as const;
const UPLOAD_DIR = path.join(process.cwd(), "public", "images", "uploads");

const availableWidths = (() => {
  if (!/\/portada-/.test(src)) return [] as number[];
  const extIdx = src.lastIndexOf(".");
  if (extIdx < 0) return [] as number[];
  const base = src.slice(0, extIdx);
  const filename = base.split("/").pop() ?? "";
  if (!filename) return [] as number[];
  return VARIANT_WIDTHS.filter((w) =>
    fs.existsSync(path.join(UPLOAD_DIR, `${filename}-${w}.webp`)),
  );
})();

const srcset = availableWidths
  .map((w) => `${src.slice(0, src.lastIndexOf("."))}-${w}.webp ${w}w`)
  .join(", ");
---

<Tag
  href={href}
  class:list={["media-item", "media-item-intrinsic", zoom && "media-zoom", className]}
>
  {availableWidths.length > 0 ? (
    <picture>
      <source
        type="image/webp"
        sizes={sizes}
        srcset={srcset}
      />
      <img
        src={src}
        alt={alt}
        loading={loading}
        decoding="async"
        fetchpriority={fetchpriority}
      />
    </picture>
  ) : (
    <img
      src={src}
      alt={alt}
      loading={loading}
      decoding="async"
      fetchpriority={fetchpriority}
    />
  )}
</Tag>

{caption && (
  <p class="versalita mt-3">
    <span class="text-[var(--color-accent)]">*</span> {caption}
  </p>
)}

<script>
  document.querySelectorAll<HTMLImageElement>(".media-item img").forEach((img) => {
    const markBroken = () => {
      img.style.display = "none";
      img.closest(".media-item")?.classList.add("is-broken");
    };
    if (img.complete && img.naturalWidth === 0) {
      markBroken();
    } else {
      img.addEventListener("error", markBroken, { once: true });
    }
  });
</script>
