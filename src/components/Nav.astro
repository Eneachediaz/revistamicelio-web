---
import Hyphae from "./Hyphae.astro";
import Sporangium from "./Sporangium.astro";
import Logo from "./Logo.astro";

const path = Astro.url.pathname;
const isActive = (href: string) => {
  if (href === "/") return path === "/";
  return path === href || path.startsWith(href + "/");
};

const items = [
  { href: "/la-revista/",   label: "La revista" },
  { href: "/publicaciones/", label: "Publicaciones" },
  { href: "/s-lab/",        label: "s-Lab" },
  { href: "/listas/",       label: "Listas" },
  { href: "/convocatoria/", label: "Convocatoria" },
  { href: "/creditos/",     label: "Bibliografía" },
];
---

<header class="pt-6 pb-2 md:pt-8">
  <nav aria-label="Navegación principal" class="container-editorial">
    <div class="flex items-center justify-between gap-3">
      <Logo size="md" />

      <button
        id="nav-toggle"
        type="button"
        class="grid size-12 place-items-center rounded-full text-[var(--color-ink)] transition hover:bg-[var(--color-surface-2)] hover:text-[var(--color-hyphae-glow)] focus-visible:bg-[var(--color-surface-2)]"
        aria-expanded="false"
        aria-controls="nav-list"
        aria-label="Abrir menú de navegación"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="size-6" aria-hidden="true">
          <line x1="4" y1="8"  x2="20" y2="8" />
          <line x1="4" y1="16" x2="20" y2="16" />
        </svg>
      </button>
    </div>

    <div class="mt-3 hidden md:block" aria-hidden="true">
      <Hyphae variant="branch" color="hyphae" />
    </div>

    <div
      id="nav-backdrop"
      class="fixed inset-0 z-40 hidden bg-black/60 backdrop-blur-sm"
      aria-hidden="true"
    ></div>

    <ul
      id="nav-list"
      class="hidden fixed inset-0 z-50 flex-col items-center justify-center gap-6 overflow-y-auto bg-[var(--color-bg)]/95 backdrop-blur-md md:gap-8"
    >
      <li>
        <button
          type="button"
          id="nav-close"
          class="versalita absolute right-4 top-4 inline-flex min-h-[2.75rem] items-center gap-2 rounded-full border border-[var(--color-border)] px-4 text-[var(--color-ink-muted)] transition hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] md:right-6 md:top-6"
          aria-label="Cerrar menú"
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="size-4" aria-hidden="true">
            <line x1="6" y1="6" x2="18" y2="18" />
            <line x1="18" y1="6" x2="6" y2="18" />
          </svg>
          <span>Cerrar</span>
        </button>
      </li>
      <li class="absolute left-1/2 top-14 -translate-x-1/2 md:top-16" aria-hidden="true">
        <Sporangium variant="cluster" color="spore" size={48} />
      </li>
      <li class="absolute left-1/2 top-28 w-64 -translate-x-1/2 md:top-32" aria-hidden="true">
        <Hyphae variant="branch" color="hyphae" />
      </li>
      {items.map((item) => (
        <li class="w-full px-6">
          <a
            href={item.href}
            aria-current={isActive(item.href) ? "page" : undefined}
            class:list={[
              "group flex min-h-[2.75rem] items-center justify-center gap-3 px-2 font-[family-name:var(--font-display)] no-underline transition",
              isActive(item.href) ? "text-[var(--color-accent)]" : "text-[var(--color-ink)] hover:text-[var(--color-accent)]",
            ]}
            style="font-variation-settings: 'opsz' 144, 'wonk' 1; font-size: clamp(1.75rem, 7vw, 3rem);"
          >
            {isActive(item.href) && (
              <span class="spore-dot" data-size="sm" aria-hidden="true"></span>
            )}
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<script is:inline>
  (function () {
    const btn = document.getElementById("nav-toggle");
    const list = document.getElementById("nav-list");
    const close = document.getElementById("nav-close");
    const backdrop = document.getElementById("nav-backdrop");
    if (!btn || !list) return;

    const open = () => {
      list.classList.remove("hidden");
      list.classList.add("flex");
      if (backdrop) {
        backdrop.classList.remove("hidden");
        backdrop.classList.add("block");
      }
      btn.setAttribute("aria-expanded", "true");
      btn.setAttribute("aria-label", "Cerrar menú de navegación");
      document.body.style.overflow = "hidden";
    };

    const closeMenu = () => {
      list.classList.add("hidden");
      list.classList.remove("flex");
      if (backdrop) {
        backdrop.classList.add("hidden");
        backdrop.classList.remove("block");
      }
      btn.setAttribute("aria-expanded", "false");
      btn.setAttribute("aria-label", "Abrir menú de navegación");
      document.body.style.overflow = "";
    };

    btn.addEventListener("click", open);
    if (close) close.addEventListener("click", closeMenu);
    if (backdrop) backdrop.addEventListener("click", closeMenu);
    document.addEventListener("keydown", (e) => { if (e.key === "Escape") closeMenu(); });
    window.addEventListener("popstate", closeMenu);
    list.querySelectorAll("a").forEach((a) => a.addEventListener("click", closeMenu));
  })();
</script>
