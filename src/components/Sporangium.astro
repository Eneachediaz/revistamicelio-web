---
/**
 * Sporangium · racimo de esporas SVG.
 * Variantes:
 *   - "cluster"  : 5-8 esporas con tamaños y posiciones irregulares
 *   - "pair"     : 2 esporas
 *   - "single"   : 1 espora grande con halo
 *   - "dust"     : 12+ esporas pequeñas dispersas
 */
interface Props {
  variant?: "cluster" | "pair" | "single" | "dust";
  color?: "spore" | "hyphae" | "accent";
  size?: number;
  className?: string;
}
const { variant = "cluster", color = "spore", size = 28, className = "" } = Astro.props;

const fill = {
  spore:  "var(--color-spore)",
  hyphae: "var(--color-hyphae)",
  accent: "var(--color-accent)",
}[color];
---
{variant === "cluster" && (
  <svg
    width={size}
    height={size * 0.6}
    viewBox="0 0 60 36"
    fill="none"
    aria-hidden="true"
    class={className}
  >
    <circle cx="10" cy="22" r="3"   fill={fill} />
    <circle cx="22" cy="14" r="2"   fill={fill} opacity="0.85" />
    <circle cx="34" cy="20" r="3.5" fill={fill} />
    <circle cx="46" cy="12" r="1.8" fill={fill} opacity="0.7" />
    <circle cx="52" cy="22" r="2.2" fill={fill} opacity="0.9" />
    <circle cx="18" cy="28" r="1.2" fill={fill} opacity="0.5" />
    <circle cx="40" cy="30" r="1.4" fill={fill} opacity="0.6" />
  </svg>
)}

{variant === "pair" && (
  <svg
    width={size}
    height={size * 0.4}
    viewBox="0 0 30 12"
    fill="none"
    aria-hidden="true"
    class={className}
  >
    <circle cx="8"  cy="6" r="3" fill={fill} />
    <circle cx="22" cy="6" r="2" fill={fill} opacity="0.75" />
  </svg>
)}

{variant === "single" && (
  <svg
    width={size}
    height={size}
    viewBox="0 0 24 24"
    fill="none"
    aria-hidden="true"
    class={className}
  >
    <circle cx="12" cy="12" r="9"  fill={fill} opacity="0.15" />
    <circle cx="12" cy="12" r="5"  fill={fill} opacity="0.35" />
    <circle cx="12" cy="12" r="2.5" fill={fill} />
  </svg>
)}

{variant === "dust" && (
  <svg
    width={size * 2.5}
    height={size * 0.8}
    viewBox="0 0 120 40"
    fill="none"
    aria-hidden="true"
    class={className}
  >
    <circle cx="6"   cy="22" r="1" fill={fill} opacity="0.7" />
    <circle cx="14"  cy="10" r="0.8" fill={fill} opacity="0.5" />
    <circle cx="22"  cy="28" r="1.2" fill={fill} opacity="0.6" />
    <circle cx="32"  cy="16" r="0.6" fill={fill} opacity="0.4" />
    <circle cx="42"  cy="32" r="1" fill={fill} opacity="0.7" />
    <circle cx="50"  cy="8"  r="0.7" fill={fill} opacity="0.5" />
    <circle cx="58"  cy="24" r="1.4" fill={fill} />
    <circle cx="68"  cy="14" r="0.5" fill={fill} opacity="0.4" />
    <circle cx="76"  cy="30" r="1" fill={fill} opacity="0.6" />
    <circle cx="86"  cy="20" r="0.8" fill={fill} opacity="0.5" />
    <circle cx="94"  cy="12" r="1.1" fill={fill} opacity="0.7" />
    <circle cx="104" cy="28" r="0.6" fill={fill} opacity="0.4" />
    <circle cx="112" cy="18" r="1" fill={fill} opacity="0.6" />
  </svg>
)}
